#include <stdio.h>
#include <stdlib.h>

#define MAX_EDGES 100
#define MAX_VERTICES 100

// Union-Find helpers
int parent[MAX_VERTICES];
int rankArr[MAX_VERTICES];

// Initialize Union-Find
void makeSet(int n) {
    for (int i = 0; i < n; i++) {
        parent[i] = i;
        rankArr[i] = 0;
    }
}

// Find with path compression
int findSet(int v) {
    if (parent[v] != v)
        parent[v] = findSet(parent[v]);
    return parent[v];
}

// Union by rank
void unionSets(int u, int v) {
    int rootU = findSet(u);
    int rootV = findSet(v);
    if (rootU != rootV) {
        if (rankArr[rootU] < rankArr[rootV]) {
            parent[rootU] = rootV;
        } else if (rankArr[rootU] > rankArr[rootV]) {
            parent[rootV] = rootU;
        } else {
            parent[rootV] = rootU;
            rankArr[rootU]++;
        }
    }
}

// Kruskal’s Algorithm
void kruskal(int edges[][3], int V, int E) {
    // Sort edges by weight (simple bubble sort for clarity)
    for (int i = 0; i < E-1; i++) {
        for (int j = 0; j < E-i-1; j++) {
            if (edges[j][2] > edges[j+1][2]) {
                int temp0 = edges[j][0];
                int temp1 = edges[j][1];
                int temp2 = edges[j][2];
                edges[j][0] = edges[j+1][0];
                edges[j][1] = edges[j+1][1];
                edges[j][2] = edges[j+1][2];
                edges[j+1][0] = temp0;
                edges[j+1][1] = temp1;
                edges[j+1][2] = temp2;
            }
        }
    }

    makeSet(V);

    printf("Edges in the Minimum Spanning Tree:\n");
    int mstWeight = 0;
    for (int i = 0; i < E; i++) {
        int u = edges[i][0];
        int v = edges[i][1];
        int w = edges[i][2];

        if (findSet(u) != findSet(v)) {
            printf("%d -- %d == %d\n", u, v, w);
            mstWeight += w;
            unionSets(u, v);
        }
    }
    printf("Total weight of MST: %d\n", mstWeight);
}

int main() {
    int V = 4; // number of vertices
    int E = 5; // number of edges

    // Each edge: {src, dest, weight}
    int edges[MAX_EDGES][3] = {
        {0, 1, 10},
        {0, 2, 6},
        {0, 3, 5},
        {1, 3, 15},
        {2, 3, 4}
    };

    kruskal(edges, V, E);

    return 0;
}
